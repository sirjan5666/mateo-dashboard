# ── Mateo — production server environment ────────────────────────────────────
# This documents every variable the server reads. setup-server.sh generates the
# required ones automatically; you only fill in the OPTIONAL integrations later.
# The server validates these at boot (server/src/config/env.ts) and REFUSES to
# start in production without a valid DATA_ENCRYPTION_KEY.

NODE_ENV=production
PORT=4000

# MongoDB — self-hosted on this box, localhost-only, auth on.
# setup-server.sh creates the "mateoapp" user and writes the real URI for you.
MONGODB_URI=mongodb://mateoapp:CHANGE_ME@127.0.0.1:27017/mateo?authSource=mateo

# JWT signing secret (32+ chars). Generated for you. Regenerate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# PHI field-encryption key — 32 bytes, base64, MUST differ from JWT_SECRET.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️  Back this up. If it's ever lost, existing encrypted patient data is unrecoverable.
DATA_ENCRYPTION_KEY=

# Public HTTPS URL of the site — used in credential-invite emails.
APP_BASE_URL=https://YOUR_DOMAIN

# ── Optional (blank = feature degrades gracefully, app still runs) ────────────
# Razorpay LIVE keys — required for parents to BUY the plan (the dev mock is
# disabled in production). Blank = launch without paid self-purchase.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP — credential-invite + admin order emails. Blank = doctor sees the
# credentials on-screen instead (show-once panel).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=

# AI assistant (Tara). Blank = Tara is hidden. Set ONE provider.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
