# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/mateo-dashboard

# Random secret for signing JWTs, at least 32 chars
# e.g. node -e "console.log(crypto.randomBytes(32).toString('hex'))"
JWT_SECRET=

PORT=4000

# AI assistant (optional — the app + red-flag safety gate run without it).
# Provider is auto-selected: DeepSeek if DEEPSEEK_API_KEY is set, else Anthropic.
# DeepSeek (OpenAI-compatible):
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# Anthropic (alternative):
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
